#!/bin/sh

set -euo pipefail

# Creating temporary file
tmpfile=$(mktemp)

# Handle interrupts
trap 'rm -f "$tmpfile"' EXIT

# Read stdin into file
if [[ -t 0 ]]; then
	: > "$tmpfile"
else
	cat > "$tmpfile"
fi

# Open editor
"${EDITOR:-vi}" "$tmpfile" </dev/tty >/dev/tty 2>&1

# Output result
cat "$tmpfile"

# Cleanup
rm "$tmpfile"
