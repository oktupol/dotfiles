#!/bin/zsh

# List every saved Wi-Fi network alongside its stored password (PSK), by
# querying NetworkManager. Handy for sharing or recovering forgotten keys.

# For each Wi-Fi connection name produced below, pull its secret PSK and,
# if one exists, print the network name, the password, and a blank separator.
while read connection; do
	password="$(nmcli connection show "$connection" --show-secrets | grep '^802-11-wireless-security\.psk:' | awk '{ print $2 }')"
	if [[ -n "$password" ]]; then
		echo $connection
		echo $password
		echo ''
	fi
# Feed the loop with the names of all wifi-type connections. The fixed
# FIELDWIDTHS parse nmcli's columnar output; trailing spaces are trimmed and
# only rows whose TYPE column is "wifi" are kept.
done < <(nmcli connection show | awk 'BEGIN { FIELDWIDTHS = "34 38 11 10" }
	NR > 1 {
		name = $1
		type = $3

		sub(/ +$/, "", name)
		sub(/ +$/, "", type)

		if (type == "wifi")
			print name
	}')
